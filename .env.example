# Plantilla de variables de entorno.
# Copia este archivo a `.env` y rellena tus valores locales o de producción.
# NO subas tu archivo `.env` al repositorio con valores reales.

# Módulo de settings de Django (por defecto para desarrollo o producción)
DJANGO_SETTINGS_MODULE='config.settings.local'   # Ej: 'config.settings.produccion'

# Modo DEBUG: 'True' para desarrollo local, 'False' para producción
DEBUG ='False'

# Clave secreta de Django (cópiala desde settings.py a tu `.env` privado)
SECRET_KEY='your-secret-key-here'

# Conexión a la base de datos. Se recomienda usar `DATABASE_URL` en formato RFC solo en producción.:
# postgresql://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL='postgresql://USER:PASSWORD@HOST:PORT/DB_NAME'
# Alternativamente puedes usar variables individuales en desarrollo local (descomentar y rellenar):
# DB_NAME='your_database_name'
# DB_USER='your_database_user'
# DB_PASSWORD='your_database_password'
# DB_HOST='localhost'
# DB_PORT='5432'

# --- SUPABASE STORAGE / S3 (opcional, usado en producción) ---
AWS_STORAGE_BUCKET_NAME='your-bucket-name'          # Nombre del bucket (ej: media)
AWS_ACCESS_KEY_ID='your-access-key-id'
AWS_SECRET_ACCESS_KEY='your-secret-access-key'
# URL del endpoint S3 de tu proyecto Supabase (ej: https://<project-ref>.supabase.co/storage/v1)
AWS_S3_ENDPOINT_URL='https://your-project-ref.supabase.co/storage/v1'

# API Keys externas
GOOGLE_API_KEY='your-google-api-key'

# --- Claves de Google reCAPTCHA v2 ---
RECAPTCHA_SITE_KEY='your-recaptcha-site-key'
RECAPTCHA_SECRET_KEY='your-recaptcha-secret-key'

# Notas:
# - Mantén este archivo con placeholders; copia a `.env` y añade los valores reales localmente.
# - No incluyas credenciales reales en el control de versiones.
# - Para producción, utiliza un gestor de secretos o variables de entorno del entorno de despliegue.