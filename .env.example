# Plantilla de variables de entorno. Copia este archivo a .env y rellena tus valores.

SECRET_KEY='your-secret-key-here'   # Copia la clave secreta de Django aquí (no compartas este valor)
DB_NAME='your_database_name'        # Nombre de la base de datos local
DB_USER='your_database_user'
DB_PASSWORD='your_database_password'
DB_HOST='localhost'
DB_PORT='5432'

# Esto únicamente es para producción, no lo uses en desarrollo
# Credenciales de Supabase Storage / S3
# --- SUPABASE STORAGE (S3) ---
AWS_STORAGE_BUCKET_NAME='your-bucket-name'          # Nombre del bucket (ej: media)
AWS_ACCESS_KEY_ID='your-access-key-id'
AWS_SECRET_ACCESS_KEY='your-secret-access-key'
# URL pública de almacenamiento de tu proyecto Supabase (reemplaza your-project-ref)
AWS_S3_ENDPOINT_URL='https://your-project-ref.supabase.co/storage/v1'